# 智谱 AI API 密钥
ZHIPU_API_KEY=your_zhipu_api_key_here

# 服务配置
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# 向量数据库配置
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=knowledge_base

# 文件上传配置
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE=10485760

# RAG 配置
CHUNK_SIZE=800
CHUNK_OVERLAP=200
TOP_K=3
TEMPERATURE=0.7

# 模型配置
LLM_MODEL=glm-4-air
EMBEDDING_MODEL=embedding-3

# 日志配置
LOG_LEVEL=INFO
